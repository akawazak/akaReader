{
  "name": "akareader",
  "version": "1.1.3",
  "description": "Manga reader powered by Suwayomi",
  "main": "electron-main.js",
  "author": {
    "name": "akawazak",
    "email": "akawazak@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akawazak/akaReader"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean": "rimraf dist dist-electron",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "rimraf dist dist-electron && vite build && electron-builder --win",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.263.1",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0",
    "rimraf": "^5.0.0"
  },
  "build": {
    "appId": "com.akareader.app",
    "productName": "akaReader",
    "publish": {
      "provider": "github",
      "owner": "akawazak",
      "repo": "akaReader",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**"
        ]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icon.png",
      "category": "Utility",
      "maintainer": "akawazak <akawazak@users.noreply.github.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}